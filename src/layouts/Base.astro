---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import business from '../data/business.json';

interface Props {
  title: string;
  description: string;
  faq?: { question: string; answer: string }[];
}

const { title, description, faq } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "description": "Custom solid hardwood murphy beds for Ottawa homes. Handbuilt by Mennonite craftsmen in Southern Ontario. 100% Canadian made. Visit The New Oak Tree showroom inside Kessels Upholstery at 107 Colonnade Road North.",
  "url": business.url,
  "telephone": business.phoneTel,
  "email": business.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": business.address.streetAddress,
    "addressLocality": business.address.addressLocality,
    "addressRegion": business.address.addressRegion,
    "postalCode": business.address.postalCode,
    "addressCountry": business.address.addressCountry
  },
  "openingHours": business.schemaOpeningHours,
  "priceRange": "$$",
  "areaServed": {
    "@type": "City",
    "name": "Ottawa"
  },
  "hasMap": business.googleMapsUrl
};

const faqSchema = faq ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
} : null;
---

<!DOCTYPE html>
<html lang="en-CA">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={business.url} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={business.url} />
  <meta property="og:locale" content="en_CA" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Structured Data: LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Structured Data: FAQ -->
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
