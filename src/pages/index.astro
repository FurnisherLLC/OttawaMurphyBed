    color: var(--color-slate);
  }

  .gallery__config {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  /* ==================== CUSTOMIZE ==================== */
  .customize {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 5rem;
    align-items: start;
  }

  .customize__intro p {
    font-size: 1.02rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .customize__options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
