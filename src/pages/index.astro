  description="Custom solid hardwood murphy beds for Ottawa. Handbuilt by Mennonite craftsmen in Southern Ontario. Every wood, stain, and configuration available. Starting at $3,800 installed. Call 343-338-0380."
  faq={faq}
>

  <!-- ==================== HERO ==================== -->
  <section class="hero">
    <div class="hero__stage">
      <img
        class="hero__img"
        src="/images/hero-cinematic-edit.webp"
        alt="Solid hardwood murphy bed open in a warm evening room"
