---
import Base from '../layouts/Base.astro';
import business from '../data/business.json';

const faq = [
  {
    question: "What is a murphy bed?",
    answer: "A murphy bed, also called a wall bed or fold-down bed, is a bed that folds into a wall cabinet when not in use. When closed it looks like a piece of furniture. When open it is a fully functional bed with a standard mattress. Murphy beds are ideal for condos, small apartments, home offices, and any room that needs to serve more than one purpose."
  },
  {
    question: "How much does a murphy bed cost in Ottawa?",
    answer: "Our solid hardwood murphy beds are priced depending on size, wood species, stain, and configuration. Unlike mass-market options built from particle board or veneer, these are built to last — from real wood, by hand, in Ontario. Contact us at 343-338-0380 for a specific quote."
  },
  {
    question: "What makes your murphy beds different from what I see online?",
    answer: "Most murphy beds sold online or in big-box stores are built from particle board or MDF with a veneer surface. Ours are solid hardwood, built by Mennonite craftsmen in Southern Ontario using the same construction standards as fine furniture. The difference is visible and tangible. These are not flat-pack beds."
  },
  {
    question: "What can I customize?",
    answer: "Everything. Wood species (including maple, walnut, oak, and others), stain or finish, bed size (twin, double, queen), orientation (vertical or horizontal), side shelving units, integrated fold-down desk, cabinet panel design, and hardware. Every bed is built to your specification."
  },
  {
    question: "Where can I see one in person and discuss my options?",
    answer: "Visit The New Oak Tree showroom, inside Kessels Upholstery at 107 Colonnade Road North, Unit 7, Ottawa, ON K2E 7M3. Our team can walk you through options, discuss your room, and help you configure exactly what you need. Open Monday to Friday 9 AM to 5 PM, Saturday 9 AM to 4 PM, Sunday 11 AM to 3 PM. No appointment needed."
  },
  {
    question: "How long does installation take?",
    answer: "Professional installation typically takes half a day to a full day depending on configuration and wall type. We handle delivery and installation in Ottawa and the surrounding area. Call 343-338-0380 to discuss your timeline."
  },
  {
    question: "Is a murphy bed comfortable to sleep on?",
    answer: "Yes. A murphy bed uses a standard mattress, not a foldout sofa mattress or air mattress. Comfort is comparable to a conventional bed. The spring-counterbalanced hardware keeps the mattress perfectly flat and makes opening and closing effortless regardless of mattress weight."
  }
];
---

<Base
  title="Ottawa Murphy Bed | Solid Hardwood Wall Beds, Built in Canada"
  description="Custom solid hardwood murphy beds for Ottawa. Handbuilt by Mennonite craftsmen in Southern Ontario. Every wood, stain, and configuration available. Visit our Ottawa showroom or call 343-338-0380."
  faq={faq}
>

  <!-- ==================== HERO ==================== -->
  <section class="hero">
    <div class="hero__overlay"></div>
    <div class="hero__inner container">
      <p class="hero__eyebrow">Handbuilt in Canada &bull; Southern Ontario Mennonite Craft</p>
      <h1>Solid Hardwood<br />Murphy Beds</h1>
      <p class="hero__sub">
        Not particle board. Not veneer. Real wood, built by hand,
        to your exact specification. Ottawa's source for heirloom-quality wall beds.
      </p>
      <div class="hero__actions">
        <a href={`tel:${business.phoneTel}`} class="btn btn-phone">
          Call {business.phone}
        </a>
        <a href="#showroom" class="btn btn-outline-cream">
          Visit the Showroom
        </a>
      </div>
    </div>
  </section>


  <!-- ==================== CRAFT STATEMENT ==================== -->
  <section class="section section--slate">
    <div class="container craft">
      <div class="craft__text">
        <p class="section-label section-label--light">The Difference</p>
        <h2>Built the way furniture<br />used to be built.</h2>
        <div class="oak-rule oak-rule--left"></div>
        <p>
          Every murphy bed we sell is crafted by Mennonite woodworkers in Southern Ontario
          from solid hardwood. No particle board core. No veneer surface. No shortcuts.
          The same construction principles that have defined fine furniture for generations.
        </p>
        <p>
          100% Canadian made. When you order from us, a craftsman in Ontario builds your
          bed by hand to your exact specification. It ships to Ottawa and we install it.
          The result is a piece of furniture that will outlast the room it is in.
        </p>
        <div class="craft__marks">
          <div class="craft__mark">
            <span class="craft__mark-label">Material</span>
            <span class="craft__mark-value">Solid hardwood</span>
          </div>
          <div class="craft__mark">
            <span class="craft__mark-label">Made in</span>
            <span class="craft__mark-value">Canada</span>
          </div>
          <div class="craft__mark">
            <span class="craft__mark-label">Built by</span>
            <span class="craft__mark-value">Mennonite craftsmen, Southern Ontario</span>
          </div>
        </div>
      </div>
      <div class="craft__image">
        <img
          src="/images/bed-background.png"
          alt="Solid hardwood murphy bed open in a room, showing built-in shelving and natural wood construction"
          width="600"
          height="600"
          loading="eager"
        />
      </div>
    </div>
  </section>


  <!-- ==================== GALLERY ==================== -->
  <section class="section section--cream" id="gallery">
    <div class="container">
      <div class="text-center gallery__header">
        <p class="section-label">The Work</p>
        <h2>Every finish is different.<br />Yours is built to order.</h2>
        <div class="oak-rule"></div>
        <p class="gallery__sub">
          Wood species, stain, shelving, desk, size, orientation. All of it is yours to specify.
          The beds below are examples of what comes out of the workshop.
        </p>
      </div>
      <div class="gallery__grid">
        <div class="gallery__item gallery__item--wide">
          <img
            src="/images/bed-maple-sides.jpg"
            alt="Murphy bed closed, maple finish with side shelving units"
            width="1024"
            height="1024"
            loading="lazy"
          />
          <div class="gallery__caption">
            <span class="gallery__finish">Maple</span>
            <span class="gallery__config">With side shelving &bull; Closed</span>
          </div>
        </div>
        <div class="gallery__item">
          <img
            src="/images/bed-open.png"
            alt="Murphy bed open, maple finish with side shelving, showing the transformation from cabinet to bed"
            width="1024"
            height="1024"
            loading="lazy"
          />
          <div class="gallery__caption">
            <span class="gallery__finish">Maple</span>
            <span class="gallery__config">With side shelving &bull; Open</span>
          </div>
        </div>
        <div class="gallery__item">
          <img
            src="/images/bed-walnut-nosides.png"
            alt="Murphy bed closed, walnut finish without side shelving"
            width="1024"
            height="1024"
            loading="lazy"
          />
          <div class="gallery__caption">
            <span class="gallery__finish">Walnut</span>
            <span class="gallery__config">No side shelving &bull; Closed</span>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ==================== CUSTOMIZE ==================== -->
  <section class="section section--white">
    <div class="container customize">
      <div class="customize__intro">
        <p class="section-label">Configuration</p>
        <h2>Specify everything.</h2>
        <div class="oak-rule oak-rule--left"></div>
        <p>
          There is no standard model. Every bed is built to your room and your preferences.
          Tell us what you want and we will tell you what it costs.
        </p>
        <a href={`tel:${business.phoneTel}`} class="btn btn-primary" style="margin-top: 1.5rem;">
          Call {business.phone}
        </a>
      </div>
      <div class="customize__options">
        <div class="option">
          <h3>Wood species</h3>
          <p>Maple, walnut, oak, and other solid hardwoods. Each species has a distinct grain character and takes stain differently.</p>
        </div>
        <div class="option">
          <h3>Stain and finish</h3>
          <p>Natural, light, medium, dark, or custom stain. The walnut and maple renders on this page show just two of many possible outcomes.</p>
        </div>
        <div class="option">
          <h3>Bed size</h3>
          <p>Twin, double, or queen. Vertical or horizontal orientation depending on ceiling height and wall width.</p>
        </div>
        <div class="option">
          <h3>Side shelving</h3>
          <p>Full-height shelving towers on one or both sides, or a clean standalone cabinet panel with no shelving.</p>
        </div>
        <div class="option">
          <h3>Integrated desk</h3>
          <p>A fold-down desk that remains usable when the bed is open. The classic home office that converts to a guest room at night.</p>
        </div>
        <div class="option">
          <h3>Cabinet panel design</h3>
          <p>Panel layout, hardware finish (brushed nickel, matte black, and more), and door configuration to match your space.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ==================== HOW IT WORKS ==================== -->
  <section class="section section--slate">
    <div class="container">
      <div class="text-center">
        <p class="section-label section-label--light">The Process</p>
        <h2>How it works</h2>
        <div class="oak-rule"></div>
      </div>
      <div class="steps">
        <div class="step">
          <div class="step__num">1</div>
          <h3>Visit the showroom</h3>
          <p>
            Come to The New Oak Tree inside Kessels Upholstery at 107 Colonnade Road North.
            Bring your room dimensions. Our team will walk you through your options.
          </p>
        </div>
        <div class="step">
          <div class="step__num">2</div>
          <h3>Specify your bed</h3>
          <p>
            Choose your wood, stain, size, orientation, and configuration. We order it
            built to your specification by our craftsmen in Southern Ontario.
          </p>
        </div>
        <div class="step">
          <div class="step__num">3</div>
          <h3>Delivery and installation</h3>
          <p>
            We deliver and install in Ottawa. Measured to fit, secured to the wall,
            and ready to use. Professional installation included.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ==================== SHOWROOM ==================== -->
  <section class="section section--cream" id="showroom">
    <div class="container showroom">
      <div class="showroom__info">
        <p class="section-label">Ottawa Showroom</p>
        <h2>Come talk to us.</h2>
        <div class="oak-rule oak-rule--left"></div>
        <p>
          The New Oak Tree showroom is inside Kessels Upholstery at 107 Colonnade Road
          North in Ottawa. Walk in during business hours and we will talk through your
          project. No appointment needed.
        </p>
        <p>
          Pre-orders welcome. If you have a space in mind and want to get the ball rolling
          before visiting, call us.
        </p>
        <div class="showroom__contact">
          <a href={`tel:${business.phoneTel}`} class="btn btn-primary">
            Call {business.phone}
          </a>
          <a href={`mailto:${business.email}`} class="btn btn-outline">
            Email Us
          </a>
        </div>
        <div class="showroom__details">
          <div>
            <p class="detail-label">Address</p>
            <address>
              {business.address.streetAddress}<br />
              {business.address.addressLocality}, {business.address.addressRegion} {business.address.postalCode}<br />
              <a href={business.hostedAtUrl} target="_blank" rel="noopener">Inside {business.hostedAt}</a>
            </address>
            <a href={business.googleMapsUrl} target="_blank" rel="noopener" class="map-link">Get directions &rarr;</a>
          </div>
          <div>
            <p class="detail-label">Hours</p>
            {business.openingHours.map(h => (
              <div class="hours-row">
                <span>{h.days}</span>
                <span>{h.closes ? `${h.opens} - ${h.closes}` : h.opens}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="showroom__visual">
        <img
          src="/images/hero.png"
          alt="Solid hardwood murphy bed open in a bright room, showing natural wood grain and side shelving"
          width="960"
          height="600"
          loading="lazy"
        />
      </div>
    </div>
  </section>


  <!-- ==================== FAQ ==================== -->
  <section class="section section--white" id="faq">
    <div class="container faq">
      <div class="text-center" style="margin-bottom: 3rem;">
        <p class="section-label">Questions</p>
        <h2>FAQ</h2>
        <div class="oak-rule"></div>
      </div>
      <div class="faq__grid">
        {faq.map(item => (
          <details class="faq__item">
            <summary class="faq__question">{item.question}</summary>
            <p class="faq__answer">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>


  <!-- ==================== FINAL CTA ==================== -->
  <section class="section section--slate cta-final">
    <div class="container text-center">
      <h2>Ready to build yours?</h2>
      <div class="oak-rule"></div>
      <p class="cta-final__sub">
        Call us or stop by the showroom at 107 Colonnade Road North, Ottawa.<br />
        Monday to Friday 9 AM to 5 PM &bull; Saturday 9 AM to 4 PM &bull; Sunday 11 AM to 3 PM
      </p>
      <div class="cta-final__actions">
        <a href={`tel:${business.phoneTel}`} class="btn btn-phone">
          Call {business.phone}
        </a>
        <a href={business.googleMapsUrl} target="_blank" rel="noopener" class="btn btn-outline-cream">
          Get Directions
        </a>
      </div>
    </div>
  </section>

</Base>


<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    background-image: url('/images/hero.png');
    background-size: cover;
    background-position: center 35%;
    color: var(--color-cream);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(26, 37, 53, 0.92) 0%,
      rgba(26, 37, 53, 0.75) 55%,
      rgba(26, 37, 53, 0.3) 100%
    );
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .hero__eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-oak-light);
    margin-bottom: 1.5rem;
    display: block;
  }

  .hero h1 {
    color: var(--color-cream);
    font-size: clamp(2.8rem, 7vw, 5rem);
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }

  .hero__sub {
    max-width: 520px;
    font-size: 1.1rem;
    line-height: 1.75;
    color: rgba(245, 242, 237, 0.88);
    margin-bottom: 2.5rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__actions .btn,
  .cta-final__actions .btn {
    font-size: 1.1rem;
    padding: 1rem 2.5rem;
  }

  /* ---- Craft ---- */
  .craft {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .craft__text p {
    color: rgba(245, 242, 237, 0.85);
    margin-bottom: 1.25rem;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .craft__marks {
    margin-top: 2rem;
    border-top: 1px solid rgba(245, 242, 237, 0.15);
  }

  .craft__mark {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 2rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(245, 242, 237, 0.15);
  }

  .craft__mark-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(245, 242, 237, 0.45);
    flex-shrink: 0;
  }

  .craft__mark-value {
    font-size: 0.95rem;
    color: var(--color-cream);
    font-weight: 500;
    text-align: right;
  }

  .craft__image img {
    width: 100%;
    height: 560px;
    object-fit: cover;
    border-radius: 2px;
  }

  /* ---- Gallery ---- */
  .gallery__header {
    margin-bottom: 3rem;
  }

  .gallery__sub {
    max-width: 560px;
    margin: 0 auto;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .gallery__item img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 2px;
    display: block;
    background-color: var(--color-cream-dark);
  }

  .gallery__item--wide img {
    aspect-ratio: 4 / 3.5;
  }

  .gallery__caption {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.75rem 0 0;
    border-top: 2px solid var(--color-oak);
    margin-top: 0.75rem;
  }

  .gallery__finish {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-slate);
  }

  .gallery__config {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  /* ---- Customize ---- */
  .customize {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 5rem;
    align-items: start;
  }

  .customize__intro p {
    font-size: 1.02rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .customize__options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--color-border);
    border-left: 1px solid var(--color-border);
  }

  .option {
    padding: 1.75rem;
    border-bottom: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
  }

  .option h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    color: var(--color-slate);
  }

  .option p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  /* ---- Steps ---- */
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-top: 3rem;
  }

  .step {
    border-top: 2px solid var(--color-oak);
    padding-top: 1rem;
  }

  .step__num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 900;
    color: var(--color-oak);
    opacity: 0.35;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .step h3 {
    color: var(--color-cream);
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .step p {
    font-size: 0.925rem;
    color: rgba(245, 242, 237, 0.72);
    line-height: 1.65;
  }

  /* ---- Showroom ---- */
  .showroom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .showroom__info p {
    font-size: 1.02rem;
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }

  .showroom__contact {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .showroom__details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }

  .detail-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin-bottom: 0.6rem;
    display: block;
  }

  address {
    font-style: normal;
    font-size: 0.9rem;
    line-height: 1.75;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .map-link {
    font-size: 0.875rem;
    color: var(--color-oak);
    font-weight: 600;
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--color-border);
    gap: 1rem;
  }

  .hours-row:last-child { border-bottom: none; }

  .showroom__visual img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    border-radius: 2px;
  }

  /* ---- Section labels ---- */
  .section-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-oak);
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-label--light {
    color: var(--color-oak-light);
  }

  /* ---- FAQ ---- */
  .faq__grid {
    max-width: 780px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq__item {
    background-color: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    overflow: hidden;
  }

  .faq__item[open] { border-color: var(--color-oak); }

  .faq__question {
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-slate);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    user-select: none;
  }

  .faq__question::-webkit-details-marker { display: none; }

  .faq__question::after {
    content: '+';
    font-size: 1.4rem;
    font-weight: 300;
    flex-shrink: 0;
    color: var(--color-oak);
  }

  .faq__item[open] .faq__question::after { content: '\2212'; }

  .faq__answer {
    padding: 0 1.5rem 1.25rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* ---- Final CTA ---- */
  .cta-final h2 { color: var(--color-cream); }

  .cta-final__sub {
    max-width: 560px;
    margin: 1.5rem auto 0;
    font-size: 1rem;
    color: rgba(245, 242, 237, 0.7);
    line-height: 1.8;
  }

  .cta-final__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1000px) {
    .customize {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 900px) {
    .craft,
    .showroom {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .craft__image img,
    .showroom__visual img {
      height: 380px;
    }

    .gallery__grid {
      grid-template-columns: 1fr 1fr;
    }

    .gallery__item--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .hero { min-height: 80vh; }

    .steps { grid-template-columns: 1fr; }

    .customize__options { grid-template-columns: 1fr; }

    .showroom__details { grid-template-columns: 1fr; }
  }

  @media (max-width: 560px) {
    .gallery__grid { grid-template-columns: 1fr; }
    .gallery__item--wide { grid-column: span 1; }
  }
</style>
