</Base>


<!-- ==================== SCRIPTS ==================== -->
<script>
  // --- Craft open/closed comparison slider ---
  const craftComp = document.getElementById('craft-comparison');

  if (craftComp) {
    const closedImg = craftComp.querySelector('.craft-comp__closed') as HTMLElement;
    const handle = craftComp.querySelector('.craft-comp__handle') as HTMLElement;
    let dragging = false;
    let pos = 50;

    function setPos(clientX: number) {
      const rect = craftComp!.getBoundingClientRect();
      pos = Math.max(1, Math.min(99, ((clientX - rect.left) / rect.width) * 100));
      closedImg.style.clipPath = `inset(0 ${(100 - pos).toFixed(2)}% 0 0)`;
      handle.style.left = `${pos.toFixed(2)}%`;
    }

    // Init at 50%
    setPos(craftComp.getBoundingClientRect().left + craftComp.getBoundingClientRect().width / 2);

    handle.addEventListener('mousedown', (e) => { dragging = true; e.preventDefault(); });
    handle.addEventListener('touchstart', () => { dragging = true; }, { passive: true });
    window.addEventListener('mouseup', () => { dragging = false; });
    window.addEventListener('touchend', () => { dragging = false; });
    window.addEventListener('mousemove', (e: MouseEvent) => { if (dragging) setPos(e.clientX); });
    window.addEventListener('touchmove', (e: TouchEvent) => {
      if (dragging) setPos(e.touches[0].clientX);
    }, { passive: true });

    craftComp.addEventListener('click', (e: MouseEvent) => {
      if (!dragging) setPos(e.clientX);
    });

    // Bump the handle when the slider enters the viewport (once),
    // and again on first mouseover, to signal interactivity.
    const knob = handle.querySelector('.craft-comp__knob') as HTMLElement;
    let bumped = false;

    function bump() {
      if (bumped) return;
      bumped = true;
      knob.classList.add('craft-comp__knob--bump');
      knob.addEventListener('animationend', () => {
        knob.classList.remove('craft-comp__knob--bump');
      }, { once: true });
    }

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        // Short delay so user has a moment to see the slider before it nudges
        setTimeout(bump, 600);
        observer.disconnect();
      }
    }, { threshold: 0.6 });
    observer.observe(craftComp);

    craftComp.addEventListener('mouseenter', bump, { once: true });
  }
</script>


<style>
  /* ==================== HERO ==================== */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero__stage {
    position: absolute;
    inset: 0;
  }

  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    user-select: none;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    max-width: 640px;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  /* Dark gradient behind text so it's readable on both image variants */
  .hero__content::before {
    content: '';
    position: absolute;
    inset: -3rem -4rem;
    background: radial-gradient(ellipse at 30% 50%, rgba(26,37,53,0.75) 30%, transparent 80%);
    z-index: -1;
    pointer-events: none;
  }

  .hero__eyebrow {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-oak-light);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    color: var(--color-cream);
    font-size: clamp(2.8rem, 7vw, 5rem);
    line-height: 1.05;
    margin-bottom: 1.25rem;
  }

  .hero__sub {
    max-width: 480px;
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(245, 242, 237, 0.88);
    margin-bottom: 2.5rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__actions .btn,
  .cta-final__actions .btn {
    font-size: 1.1rem;
    padding: 1rem 2.5rem;
  }

  /* ==================== CRAFT COMPARISON ==================== */
  .craft__comparison {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 2px;
    cursor: col-resize;
    user-select: none;
  }

  .craft-comp__open,
  .craft-comp__closed {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .craft-comp__closed {
    clip-path: inset(0 50% 0 0);
  }

  .craft-comp__handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: col-resize;
    pointer-events: none;
  }

  .craft-comp__line {
    width: 2px;
    flex: 1;
    background: rgba(255,255,255,0.7);
  }

  .craft-comp__knob {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-slate);
    box-shadow: 0 2px 12px rgba(0,0,0,0.35);
    pointer-events: all;
  }

  @keyframes craft-bump {
    0%   { transform: translateY(-50%) scale(1)    translateX(0); }
    15%  { transform: translateY(-50%) scale(1.15) translateX(-8px); }
    35%  { transform: translateY(-50%) scale(1.15) translateX(8px); }
    55%  { transform: translateY(-50%) scale(1.08) translateX(-5px); }
    70%  { transform: translateY(-50%) scale(1.04) translateX(4px); }
    85%  { transform: translateY(-50%) scale(1.02) translateX(-2px); }
    100% { transform: translateY(-50%) scale(1)    translateX(0); }
  }

  .craft-comp__knob--bump {
    animation: craft-bump 0.75s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
  }

  .craft-comp__labels {
    position: absolute;
    bottom: 0.75rem;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 0.85rem;
    z-index: 11;
    pointer-events: none;
  }

  .craft-comp__labels span {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.75);
    background: rgba(0,0,0,0.28);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
  }

  /* ==================== CRAFT ==================== */
  .craft {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .craft__text p {
    color: rgba(245, 242, 237, 0.85);
    margin-bottom: 1.25rem;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .craft__marks {
    margin-top: 2rem;
    border-top: 1px solid rgba(245, 242, 237, 0.15);
  }

  .craft__mark {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 2rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(245, 242, 237, 0.15);
