    text-align: right;
  }

  /* ==================== GALLERY ==================== */
  .gallery-header { margin-bottom: 3rem; }

  .gallery__grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
